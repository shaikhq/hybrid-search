# Copy to .env and fill in real values:  cp .env.example .env
# .env is git-ignored — never commit real credentials.

# --- Db2 connection -------------------------------------------------------
DB2_HOST=localhost
DB2_PORT=50000
DB2_DATABASE=sample
DB2_USER=db2inst1
DB2_PASSWORD=your-db2-password

# --- watsonx.ai (for in-database embeddings in ingest.py) -----------------
# URL must be the embeddings endpoint AND include a ?version=YYYY-MM-DD.
WATSONX_URL=https://us-south.ml.cloud.ibm.com/ml/v1/text/embeddings?version=2024-05-01
WATSONX_APIKEY=your-watsonx-api-key
WATSONX_PROJECT_ID=your-watsonx-project-id
WATSONX_MODEL_ID=sentence-transformers/all-minilm-l6-v2

# --- Object names (optional; defaults shown) ------------------------------
DB2_SCHEMA=myschema
DB2_TABLE=chunks

# --- Db2 instance owner (for db2ts text-search admin in ingest.py) --------
DB2_INSTANCE_OWNER=db2inst1

# --- Hybrid fusion knobs (optional; defaults shown) -----------------------
# Tune against ./scripts/eval.sh. VEC_GATE drops the vector leg when its best
# cosine similarity is below this (e.g. exact error codes embed to noise).
HYBRID_W_LEX=0.5
HYBRID_W_VEC=0.5
HYBRID_VEC_GATE=0.30
HYBRID_LEX_GATE=0.0
HYBRID_POOL=50
